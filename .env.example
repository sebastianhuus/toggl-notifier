TOGGL_API_TOKEN=
TOGGL_WORKSPACE_ID=
TOGGL_PROJECT_ID=

# Google Calendar OAuth (for /api/calendar).
# Create an OAuth 2.0 Web Application credential in Google Cloud Console
# and register these redirect URIs on it:
#   http://localhost:3000/api/google_callback
#   https://<your-vercel-domain>/api/google_callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google_callback

# Google Calendar event colorId to filter on (primary-calendar personal blocks).
# Defaults to "3" (lavender / #dbadff) if unset.
# CALENDAR_COLOR_ID=3

# Upstash Redis (stores the Google refresh token after /api/google_callback).
# Values from your Upstash console → Database → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email recipient for /api/check notifications.
NOTIFY_EMAIL=
# Optional. Gap (calendar minutes − toggl minutes) that triggers a notification.
# Defaults to 30.
# NOTIFY_THRESHOLD_MINUTES=30

# Bearer token required on protected endpoints (hello, toggl, calendar, check).
# Vercel Cron auto-sends this as Authorization: Bearer $CRON_SECRET.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional. Determines what "today" means when fetching entries.
# Vercel runs in UTC by default; set this if you want a different day boundary.
# TZ=Europe/Oslo
