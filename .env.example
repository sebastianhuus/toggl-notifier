TOGGL_API_TOKEN=
TOGGL_WORKSPACE_ID=
TOGGL_PROJECT_ID=

# Google Calendar OAuth (for /api/calendar).
# Create an OAuth 2.0 Web Application credential in Google Cloud Console
# and register these redirect URIs on it:
#   http://localhost:3000/api/google_callback
#   https://<your-vercel-domain>/api/google_callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google_callback

# Obtained by visiting /api/google_auth once and completing the consent flow.
# The callback page shows the refresh token to paste here.
GOOGLE_REFRESH_TOKEN=

# Google Calendar event colorId to filter on (primary-calendar personal blocks).
# Defaults to "3" (lavender / #dbadff) if unset.
# CALENDAR_COLOR_ID=3

# Optional. Determines what "today" means when fetching entries.
# Vercel runs in UTC by default; set this if you want a different day boundary.
# TZ=Europe/Oslo
